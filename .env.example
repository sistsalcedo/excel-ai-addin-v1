# Backend (Vercel: añade estas variables en Project Settings > Environment Variables)

# GROQ (obtén tu key en https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (obtén tu key en https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Puerto local (solo para backend en desarrollo)
PORT=4000

# Frontend: URL del backend (solo si el backend está en otro dominio; en Vercel déjalo vacío)
# VITE_BACKEND_URL=
